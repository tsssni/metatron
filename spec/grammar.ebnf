# ================================================================
# MTT Language Grammar Specification
# Extended Backus-Naur Form (EBNF)
# ================================================================
#
# Notation:
#   rule = expr ;                   production rule
#   'terminal'                      terminal string
#   rule?                           optional (0 or 1)
#   rule*                           repetition (0 or more)
#   rule+                           repetition (1 or more)
#   ( a | b )                       grouped alternatives
#   a b                             concatenation
#   a - b                           a but not b
#   <description>                   informal description
#
# ================================================================


# ================================================================
# 1. Lexical Grammar
# ================================================================

# ----------------------------------------
# 1.1 Source Text
# ----------------------------------------

source_file = top_level_item* ;

comment = '#' <any character except newline>* newline ;

whitespace = ' ' | '\t' | '\r' | '\n' ;


# ----------------------------------------
# 1.2 Identifiers
# ----------------------------------------

ident = ( letter | '_' ) ( letter | digit | '_' )* - keyword ;

# module path segments may contain hyphens, only valid in use paths
module_path_segment = ( letter | digit ) ( letter | digit | '-' )* ;

letter = 'a'..'z' | 'A'..'Z' ;
digit  = '0'..'9' ;


# ----------------------------------------
# 1.3 Keywords
# ----------------------------------------

keyword
    # declarations
    = 'fn' | 'struct' | 'enum' | 'bitflag'
    | 'tag' | 'concept' | 'derive' | 'alias'
    | 'layout' | 'table'
    # variables
    | 'view' | 'const'
    # visibility
    | 'hidden'
    # modules
    | 'use'
    # control flow
    | 'if' | 'else' | 'for' | 'in' | 'while' | 'loop'
    | 'match' | 'return' | 'break' | 'continue'
    # type conversion
    | 'as' | 'to'
    # self
    | 'self' | 'Self'
    # literals
    | 'none' | 'true' | 'false'
    # assertions
    | 'static_assert'
    # composite type constructors
    | 'ptr' | 'buf' | 'union'
    # type qualifiers
    | 'shared' | 'uniform' | 'atomic' | 'view'
    # generics
    | 'where' | 'requires'
    # scalar types
    | 'bool'
    | 'i8' | 'i16' | 'i32' | 'i64'
    | 'u8' | 'u16' | 'u32' | 'u64'
    | 'f16' | 'f32' | 'f64'
    # vector types
    | 'fv2' | 'fv3' | 'fv4'
    | 'iv2' | 'iv3' | 'iv4'
    | 'uv2' | 'uv3' | 'uv4'
    | 'bv2' | 'bv3' | 'bv4'
    # matrix types
    | 'fm22' | 'fm33' | 'fm44'
    # quaternion
    | 'fq'
    # opaque gpu types
    | 'Texture_2D' | 'Texture_3D' | 'Sampler'
    | 'Acceleration_Structure' | 'Ray_Query'
    ;


# ----------------------------------------
# 1.4 Literals
# ----------------------------------------

literal
    = int_literal
    | float_literal
    | bool_literal
    | string_literal
    | 'none'
    ;

# 1 = i32 (strict), 1u = u32, 1i = i32 (explicit)
int_literal     = decimal_int | hex_int | binary_int ;
decimal_int     = digit ( '_'? digit )* int_suffix? ;
hex_int         = '0x' hex_digit ( '_'? hex_digit )* int_suffix? ;
binary_int      = '0b' bin_digit ( '_'? bin_digit )* int_suffix? ;
int_suffix      = 'u' | 'i' ;

# 1.0 = f32, 1.0f16 = f16, 1.0f64 = f64
float_literal   = digit+ '.' digit+ exponent? float_suffix? ;
exponent        = ( 'e' | 'E' ) ( '+' | '-' )? digit+ ;
float_suffix    = 'f16' | 'f64' ;

bool_literal    = 'true' | 'false' ;

string_literal  = '"' ( <any character except '"' and '\\'> | escape_seq )* '"' ;
escape_seq      = '\\' ( 'n' | 'r' | 't' | '\\' | '"' | '0' ) ;

hex_digit       = digit | 'a'..'f' | 'A'..'F' ;
bin_digit       = '0' | '1' ;


# ----------------------------------------
# 1.5 Operators and Punctuation
# ----------------------------------------

# arithmetic
op_add = '+' ;  op_sub = '-' ;  op_mul = '*' ;  op_div = '/' ;  op_mod = '%' ;

# bitwise
op_band = '&' ;  op_bor = '|' ;  op_bxor = '^' ;  op_bnot = '~' ;
op_shl = '<<' ;  op_shr = '>>' ;

# comparison
op_eq = '==' ;  op_ne = '!=' ;
op_lt = '<' ;  op_gt = '>' ;  op_le = '<=' ;  op_ge = '>=' ;

# logical
op_and = '&&' ;  op_or = '||' ;  op_not = '!' ;

# assignment
op_assign     = '=' ;
op_add_assign = '+=' ;  op_sub_assign = '-=' ;
op_mul_assign = '*=' ;  op_div_assign = '/=' ;  op_mod_assign = '%=' ;
op_band_assign = '&=' ; op_bor_assign = '|=' ;  op_bxor_assign = '^=' ;
op_shl_assign = '<<=' ; op_shr_assign = '>>=' ;

# special
op_deref     = '\'' ;         # pointer dereference
op_question  = '?' ;          # optional propagation
op_coalesce  = '??' ;         # null coalescing: a ?? b
op_range     = '..' ;         # exclusive range
op_range_inc = '..=' ;        # inclusive range
op_arrow     = '->' ;         # return type
op_fatarrow  = '=>' ;         # match arm

# punctuation
punc_lbracket = '[' ;  punc_rbracket = ']' ;
punc_lbrace   = '{' ;  punc_rbrace   = '}' ;
punc_lparen   = '(' ;  punc_rparen   = ')' ;
punc_comma    = ',' ;  punc_semi     = ';' ;
punc_dot      = '.' ;  punc_colon    = ':' ;
punc_dcolon   = '::' ;


# ================================================================
# 2. Top-Level Items
# ================================================================

top_level_item
    = attribute* ( use_decl
                 | struct_decl
                 | enum_decl
                 | bitflag_decl
                 | tag_decl
                 | concept_decl
                 | derive_decl
                 | alias_decl
                 | layout_decl
                 | table_decl
                 | fn_decl
                 | const_decl
                 ) ;


# ----------------------------------------
# 2.1 Attributes
# ----------------------------------------

attribute = '[[' attribute_entry ( ',' attribute_entry )* ','? ']]' ;

attribute_entry = ident ( '(' attribute_args ')' )? ;

attribute_args = attribute_arg ( ',' attribute_arg )* ','? ;

attribute_arg
    = literal
    | ident
    | ident '(' attribute_args ')'
    ;


# ----------------------------------------
# 2.2 Use Declarations
# ----------------------------------------

use_decl = 'use' use_path ';' ;

use_path
    = module_path '::' '{' use_path_item ( ',' use_path_item )* ','? '}'
    | module_path
    ;

use_path_item = ident ;

module_path = module_path_segment ( '::' module_path_segment )* ;


# ----------------------------------------
# 2.3 Visibility
# ----------------------------------------

# default: visible to all (public)
# hidden: module-internal only

visibility = 'hidden' ;


# ----------------------------------------
# 2.4 Struct
# ----------------------------------------

struct_decl = visibility? 'struct' ident generic_params? '{' struct_field_list '}' ;

struct_field_list = ( struct_field ( ',' struct_field )* ','? )? ;

struct_field = visibility? ident ':' type ( '=' expr )? ;


# ----------------------------------------
# 2.5 Enum (C++ style, no associated data)
# ----------------------------------------

enum_decl = visibility? 'enum' ( '<' scalar_int_type '>' )? ident '{' enum_variant_list '}' ;

enum_variant_list = ( enum_variant ( ',' enum_variant )* ','? )? ;

enum_variant = ident ( '=' expr )? ;

scalar_int_type = 'u8' | 'u16' | 'u32' | 'u64' | 'i8' | 'i16' | 'i32' | 'i64' ;


# ----------------------------------------
# 2.6 Bitflag
# ----------------------------------------

bitflag_decl = visibility? 'bitflag' ( '<' bitflag_type '>' )? ident '{' bitflag_entry_list '}' ;

bitflag_entry_list = ( bitflag_entry ( ',' bitflag_entry )* ','? )? ;

bitflag_entry = ident '=' expr ;

bitflag_type = 'u32' | 'u64' ;


# ----------------------------------------
# 2.7 Tag (polymorphic dispatch interface)
# ----------------------------------------

# tag defines a polymorphic dispatch interface with member functions.
# Tag name becomes a type: a polymorphic handle.
# self is passed as u64 device address through callable/visible dispatch.
#
# Per-function dispatch:
#
#   fn flags {|self| -> T}                      (no attribute) → switch
#
#   [[indirect]]
#   fn sample {|self, ctx: Context| -> T}       → VFT (Metal) / callable (Vulkan)
#     self passed as u64 device address
#     subtypes MUST explicitly mark [[indirect]]
#
#   [[indirect]]
#   fn () {|self, ctx: Context| -> T}           → call operator, same as above
#
#   [[procedural]]
#   fn () {|instance: u32, origin: fv3, ...| -> Hit?}   → no self, free function
#     Metal:  [[intersection(bounding_box)]] + IFT
#     Vulkan: intersection shader in procedural hit group
#
#   [[anyhit]]
#   fn alpha_test {|instance: u32, ...| -> bool}         → no self, free function
#     Metal:  [[intersection(triangle)]] + IFT
#     Vulkan: any-hit shader in triangle hit group
#
# [[indirect]] functions can have self.
# [[procedural]] and [[anyhit]] cannot have self (use instance idx).

tag_decl = visibility? 'tag' ident '{' tag_fn_sig* '}' ;

tag_fn_sig = attribute* 'fn' fn_name fn_signature_only ;

fn_signature_only = '{' '|' param_list '|' ( '->' type )? '}' ;


# ----------------------------------------
# 2.8 Concept (compile-time generic type constraint)
# ----------------------------------------

# concept is a pure compile-time constraint for generics.
# Does not generate function tables.

concept_decl
    = visibility? 'concept' ident '{' concept_body '}'
    | visibility? 'concept' ident '=' concept_expr ';'
    ;

concept_body = concept_item* ;

concept_item
    = concept_fn_sig
    | concept_constraint
    ;

concept_fn_sig = 'fn' fn_name fn_signature_only ;

concept_constraint
    = 'Self' ':' concept_expr ';'
    | reflection_expr comparison_op expr ';'
    ;

concept_expr
    = ident ( '&' ident )*
    ;


# ----------------------------------------
# 2.9 Derive (code generation template)
# ----------------------------------------

derive_decl = visibility? 'derive' ident '{' derive_body '}' ;

derive_body = ( const_stmt | fn_decl | static_assert_stmt )* ;


# ----------------------------------------
# 2.10 Alias
# ----------------------------------------

alias_decl = visibility? 'alias' ident generic_params? '=' type ';' ;


# ----------------------------------------
# 2.11 Layout (descriptor set grouping)
# ----------------------------------------

# Groups structs into descriptor sets.
# Position in the list = set index.
# Structs with GPU resource fields (Texture, Sampler, etc.)
# generate descriptor entries; plain data fields go into parameter block.
#
# Example:
#   layout Trace_Layout [Constants, Resources]
#   # Constants → set 0, Resources → set 1

layout_decl = visibility? 'layout' ident '[' layout_item_list ']' ;

layout_item_list = ( ident ( ',' ident )* ','? )? ;


# ----------------------------------------
# 2.12 Table (shader dispatch table)
# ----------------------------------------

# Groups tag member functions into a dispatch table.
# Entries use Tag::fn_name() syntax. () is the call operator.
#
# [[indirect]] entries → Metal VFT / Vulkan callable SBT
# [[procedural]] / [[anyhit]] entries → Metal IFT / Vulkan hit groups
#
# Constraint: at most one non-indirect entry per table.
#
# Example:
#   table Trace_Table [Material::sample(), Material::(), Shape::(), Shape::alpha_test()]
#
# In kernel, bind as parameter:
#   fn trace {|layout [cb: Constants, res: Resources], table: Trace_Table, ...|

table_decl = visibility? 'table' ident '[' table_entry_list ']' ;

table_entry_list = ( table_entry ( ',' table_entry )* ','? )? ;

table_entry = ident '::' fn_name '(' ')' ;


# ----------------------------------------
# 2.13 Function
# ----------------------------------------

# Functions can be named with identifiers or operator symbols.
# Operator-named functions serve as operator overloads.
# self at any parameter position marks the owning type (accesses hidden fields).
#
# Examples:
#   fn normalize {|v: fv3| -> fv3 ... }
#   fn sample {|self: view Physical_Material, ctx: Context| -> Interaction? ... }
#   fn + {|self: Spectrum, other: Spectrum| -> Spectrum ... }
#   fn * {|s: f32, self: Spectrum| -> Spectrum ... }
#   fn () {|self: view Material, ctx: Context| -> Interaction? ... }
#
# [[indirect]] member functions (self passed as u64 device address):
#   [[indirect]]
#   fn sample {|self: view Physical_Material, ctx: Context| -> Interaction? ... }
#   [[indirect]]
#   fn () {|self: view Physical_Material, ctx: Context| -> Interaction? ... }

fn_decl = visibility? attribute* 'fn' fn_name generic_params? where_clause? capture_list? fn_body ;

fn_name = ident | operator_symbol | '(' ')' ;

operator_symbol = '+' | '-' | '*' | '/' | '%'
               | '&' | '|' | '^' | '~'
               | '<<' | '>>'
               | '==' | '!=' | '<' | '>' | '<=' | '>='
               | '!' ;

fn_body
    = '{' fn_params? fn_return? fn_content '}'
    ;

fn_params = '|' param_list '|' ;

fn_return = '->' type ;

fn_content
    = '=' expr                  # single-expression body
    | stmt*                     # statement body
    ;

param_list = ( param ( ',' param )* ','? )? ;

param
    = 'self' ':' type               # self param (any position)
    | pattern ':' type              # regular param
    ;

capture_list = '[' ( capture_item ( ',' capture_item )* ','? | '\'' ) ']' ;

capture_item = ident ;


# ================================================================
# 3. Generics and Constraints
# ================================================================

generic_params = '<' generic_param_list '>' ;

generic_param_list = generic_param ( ',' generic_param )* ','? ;

generic_param
    = ident ( ':' concept_expr )?               # type parameter with optional bound
    | 'const' ident ':' type                     # compile-time value parameter
    ;

where_clause = 'where' where_predicate ( ',' where_predicate )* ;

where_predicate
    = 'requires' '(' param_list ')' '{' concept_item* '}'
    | ident ':' concept_expr
    ;


# ================================================================
# 4. Types
# ================================================================

# Type syntax:  [qualifier] base_type [?]
#
# Qualifiers:
#   view     — read-only
#   const    — compile-time known value
#   shared   — threadgroup / workgroup memory
#   uniform  — constant buffer memory
#   atomic   — atomic operations enabled
#
# Default (no qualifier) = mutable local copy.

type = type_qualifier* base_type optional_suffix? ;

type_qualifier = 'view' | 'const' | 'shared' | 'uniform' | 'atomic' ;

optional_suffix = '?' ;

base_type
    = scalar_type
    | vector_type
    | matrix_type
    | 'fq'
    | opaque_type
    | composite_type
    | tuple_type
    | array_type
    | named_type
    ;

scalar_type
    = 'bool'
    | 'i8' | 'i16' | 'i32' | 'i64'
    | 'u8' | 'u16' | 'u32' | 'u64'
    | 'f16' | 'f32' | 'f64'
    ;

vector_type
    = 'fv2' | 'fv3' | 'fv4'
    | 'iv2' | 'iv3' | 'iv4'
    | 'uv2' | 'uv3' | 'uv4'
    | 'bv2' | 'bv3' | 'bv4'
    ;

matrix_type = 'fm22' | 'fm33' | 'fm44' ;

opaque_type
    = 'Texture_2D' '<' type_arg_list '>'
    | 'Texture_3D' '<' type_arg_list '>'
    | 'Sampler'
    | 'Acceleration_Structure'
    | 'Ray_Query'
    ;

composite_type
    = 'ptr' '<' type '>'
    | 'buf' '<' type '>'
    | 'union' ident                      # inline tagged union
    ;

# [] for both tuples and arrays:
#   [f32, fv3]       tuple
#   [f32; 64]        fixed-size array
#   [f32]            runtime array (inside buf only)

tuple_type = '[' type ',' type ( ',' type )* ','? ']' ;

array_type
    = '[' type ';' expr ']'
    | '[' type ']'
    ;

named_type = type_path ( '<' type_arg_list '>' )? ;

type_path = ident ( '::' ident )* ;

type_arg_list = type_arg ( ',' type_arg )* ','? ;

type_arg
    = type
    | ident
    | expr
    ;


# ================================================================
# 5. Statements
# ================================================================

stmt
    = var_decl
    | const_decl
    | expr_stmt
    | assign_stmt
    | if_stmt
    | for_stmt
    | while_stmt
    | loop_stmt
    | match_stmt
    | return_stmt
    | break_stmt
    | continue_stmt
    | static_assert_stmt
    | fn_decl
    ;


# ----------------------------------------
# 5.1 Variable Declaration
# ----------------------------------------

# Default = mutable local copy. view = read-only. const = compile-time.
# Uninitialized → default-initialized (zero / field defaults).
#
#   x: f32 = 1.0;                  mutable
#   x: view f32 = 1.0;             read-only
#   pi: const f32 = 3.14;          compile-time
#   [a, b]: [f32, fv3] = expr;     tuple destructure
#   {t, normal}: Hit = expr;       struct destructure

var_decl = pattern ':' type ( '=' expr )? ';' ;

const_decl
    = 'const' 'fn' fn_name generic_params? fn_body
    | 'const' for_stmt
    | 'const' if_stmt
    ;


# ----------------------------------------
# 5.2 Expression / Assignment Statement
# ----------------------------------------

expr_stmt = expr ';' ;

assign_stmt = assign_target assign_op expr ';' ;

assign_target
    = ident
    | expr '\'' ident
    | expr '\''
    | expr '[' expr ']'
    | expr '.' ident
    | expr '.' swizzle
    ;

assign_op
    = '=' | '+=' | '-=' | '*=' | '/=' | '%='
    | '&=' | '|=' | '^=' | '<<=' | '>>='
    ;


# ----------------------------------------
# 5.3 Control Flow
# ----------------------------------------

if_stmt
    = 'if' if_cond block ( 'else' 'if' if_cond block )* ( 'else' block )?
    ;

if_cond
    = expr
    | 'some' '(' pattern ')' '=' expr
    ;

for_stmt = 'for' pattern 'in' expr block ;

while_stmt = 'while' expr block ;

loop_stmt = 'loop' block ;

match_stmt = 'match' expr '{' match_arm* '}' ;

match_arm = pattern '=>' ( expr | block ) ','? ;

return_stmt = 'return' expr? ';' ;

break_stmt = 'break' ';' ;

continue_stmt = 'continue' ';' ;

static_assert_stmt = 'static_assert' '(' expr ( ',' string_literal )? ')' ';' ;

block = '{' stmt* '}' ;


# ================================================================
# 6. Patterns
# ================================================================

pattern
    = ident
    | '_'
    | literal
    | '.' ident
    | 'some' '(' pattern ')'
    | 'none'
    | '{' field_pattern_list '}'
    | '[' pattern ( ',' pattern )* ','? ']'
    ;

field_pattern_list = field_pattern ( ',' field_pattern )* ','? ;

field_pattern
    = ident
    | ident ':' pattern
    ;


# ================================================================
# 7. Expressions
# ================================================================

# Precedence (low to high):
#   1.  ??                        null coalescing
#   2.  ||                        logical or
#   3.  &&                        logical and
#   4.  |                         bitwise or
#   5.  ^                         bitwise xor
#   6.  &                         bitwise and
#   7.  == !=                     equality
#   8.  < > <= >=                 comparison
#   9.  << >>                     shift
#  10.  + -                       additive
#  11.  * / %                     multiplicative
#  12.  as to                     type cast
#  13.  - ! ~                     unary prefix
#  14.  postfix                   ' [] () . ? .[[]]
#  15.  primary                   literal, ident, {}, [], [[]]

expr = coalesce_expr ;

coalesce_expr   = or_expr ( '??' or_expr )* ;
or_expr         = and_expr ( '||' and_expr )* ;
and_expr        = bitor_expr ( '&&' bitor_expr )* ;
bitor_expr      = bitxor_expr ( '|' bitxor_expr )* ;
bitxor_expr     = bitand_expr ( '^' bitand_expr )* ;
bitand_expr     = equality_expr ( '&' equality_expr )* ;
equality_expr   = comparison_expr ( ( '==' | '!=' ) comparison_expr )* ;
comparison_expr = shift_expr ( ( '<' | '>' | '<=' | '>=' ) shift_expr )* ;
shift_expr      = additive_expr ( ( '<<' | '>>' ) additive_expr )* ;
additive_expr   = mult_expr ( ( '+' | '-' ) mult_expr )* ;
mult_expr       = cast_expr ( ( '*' | '/' | '%' ) cast_expr )* ;
cast_expr       = unary_expr ( ( 'to' | 'as' ) type )* ;

unary_expr
    = '-' unary_expr
    | '!' unary_expr
    | '~' unary_expr
    | postfix_expr
    ;

postfix_expr = primary_expr postfix_op* ;

postfix_op
    = '\'' ident                  # ptr deref + field: p'x
    | '\''                        # ptr deref: p'
    | '[' expr ']'                # index: a[i]
    | '(' arg_list ')'            # call: f(x, y)
    | '.' ident                   # field: s.x
    | '.' swizzle                 # swizzle: v.xyz
    | '.' '[[' ident ']]'        # reflective field access
    | '?'                         # optional propagation
    ;

swizzle = <1 to 4 characters from [xyzw]>
        | <1 to 4 characters from [rgba]> ;

primary_expr
    = literal
    | ident ( '::' ident )*
    | '(' expr ')'
    | '[' expr_list ']'
    | '{' construction_body '}'
    | lambda_expr
    | reflection_expr
    ;

expr_list = ( expr ( ',' expr )* ','? )? ;

arg_list = ( expr ( ',' expr )* ','? )? ;


# ----------------------------------------
# 7.1 Construction
# ----------------------------------------

construction_body
    = named_field_init ( ',' named_field_init )* ','?
    | expr ( ',' expr )* ','?
    |
    ;

named_field_init
    = ident ':' expr
    | ident
    ;


# ----------------------------------------
# 7.2 Lambda
# ----------------------------------------

lambda_expr = capture_list? '{' '|' param_list '|' fn_return? fn_content '}' ;


# ----------------------------------------
# 7.3 Range (valid in for-in)
# ----------------------------------------

range_expr
    = expr '..' expr
    | expr '..=' expr
    ;


# ----------------------------------------
# 7.4 Reflection
# ----------------------------------------

reflection_expr
    = '[[' 'fields' '(' type ')' ']]'
    | '[[' 'size'   '(' type ')' ']]'
    | '[[' 'align'  '(' type ')' ']]'
    | '[[' 'name'   '(' expr ')' ']]'
    | '[[' 'type'   '(' expr ')' ']]'
    | '[[' 'offset' '(' expr ')' ']]'
    | '[[' 'types'  '(' ident ')' ']]'
    ;


# ================================================================
# 8. System Values
# ================================================================

# sv:: namespace, used as kernel parameter types.
#   sv::dispatch_thread_id      uv3
#   sv::group_id                uv3
#   sv::group_thread_id         uv3
#   sv::group_index             u32


# ================================================================
# 9. Type Conversion
# ================================================================

# 'to' — value conversion:   count to f32
# 'as' — bitcast:            x as u32
# implicit — lossless widening + literal adaptation


# ================================================================
# 10. Operator Precedence Table
# ================================================================

#  Prec  | Assoc | Operators
# -------+-------+-----------------------------
#   1    | left  | ??
#   2    | left  | ||
#   3    | left  | &&
#   4    | left  | |
#   5    | left  | ^
#   6    | left  | &
#   7    | left  | == !=
#   8    | left  | < > <= >=
#   9    | left  | << >>
#  10    | left  | + -
#  11    | left  | * / %
#  12    | left  | to  as
#  13    | right | - ! ~
#  14    | left  | ' [] () . ? .[[]]
#  15    | -     | literal ident {} [] [[]]


# ================================================================
# 11. Naming Conventions
# ================================================================

# keywords:             fn view const struct enum tag concept derive layout table ...
# types / structs:      Physical_Material, Path_State
# functions / vars:     normalize, max_depth, pi
# modules / files:      core, render, monte-carlo
